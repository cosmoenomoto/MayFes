<div class="min-h-screen bg-gradient-to-br from-blue-900 via-blue-700 to-indigo-900 p-4 md:p-10 flex flex-col justify-center items-center">
  
  <div class="w-full max-w-xl bg-white/95 backdrop-blur-sm p-10 rounded-[2.5rem] shadow-2xl border border-white/20">

    <header class="text-center mb-10">
      <h1 class="text-5xl md:text-6xl font-black text-gray-950 tracking-tighter italic">MAY POS</h1>
      <div class="mt-1 bg-gray-950 text-white px-4 py-1.5 rounded-full text-xs font-bold inline-block tracking-widest animate-pulse">2026 Fest</div>
    </header>

    <% if notice %>
      <div class="fixed top-6 left-1/2 -translate-x-1/2 w-96 z-50 bg-gray-950/90 text-white shadow-2xl border border-white/20 p-5 rounded-2xl flex items-center gap-4 animate-bounce text-center">
        <span class="text-3xl text-green-400">⚡</span>
        <span class="text-sm font-bold tracking-wider"><%= notice %></span>
      </div>
    <% end %>

    <div class="mb-10 text-center">
      <p class="text-xs font-bold text-gray-500 mb-3 uppercase tracking-widest">Recent Sales Feed</p>
      <div class="flex gap-3 justify-center overflow-x-auto pb-2">
        <% @sales.first(5).each do |s| %>
          <div class="flex-shrink-0 bg-blue-50 border border-blue-100 px-4 py-3 rounded-2xl shadow-sm text-xs font-black">
            <span class="text-blue-700"><%= s.item_type_jp %></span>
            <span class="text-blue-300 mx-2">|</span>
            <span class="text-gray-600"><%= s.gender_jp %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-8">
      <% [
        { name: '商品A', type: 'item_a', price: 500, color: 'from-blue-600 via-blue-700 to-indigo-800' },
        { name: '商品B', type: 'item_b', price: 700, color: 'from-rose-600 via-rose-700 to-red-800' }
      ].each do |item| %>
        
        <div class="bg-gray-50 p-8 rounded-[2rem] border border-gray-100 shadow-inner">
          <div class="flex justify-between items-center mb-6 px-3">
            <span class="text-3xl font-black text-gray-950 italic"><%= item[:name] %></span>
            <span class="bg-white px-5 py-2.5 rounded-full text-lg font-black text-gray-800 shadow-sm border border-gray-100 tracking-tight"><%= item[:price] %>円</span>
          </div>

          <div class="grid grid-cols-2 gap-5">
            <% [ ['male', '♂ 男'], ['female', '♀ 女'] ].each do |g_key, g_name| %>
              <% [ ['young', '10-20'], ['adult', '30+'] ].each do |a_key, a_name| %>
                <%= button_to sales_path(sale: { item_type: item[:type], gender: g_key, age_group: a_key, price: item[:price] }), 
                    class: "relative overflow-hidden bg-gradient-to-br #{item[:color]} text-white p-8 rounded-3xl shadow-xl active:scale-95 transition-all text-left group min-h-[140px]" do %>
                  <div class="text-sm opacity-80 font-bold mb-1 tracking-wider"><%= a_name %></div>
                  <div class="text-lg font-black tracking-tight"><%= g_name %></div>
                  
                  <div class="absolute -right-2 -bottom-2 text-6xl opacity-10 group-hover:scale-125 transition-transform">💰</div>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-16 mb-6 text-center px-4">
      <%= link_to manage_sales_path, class: "inline-flex items-center justify-center gap-3 bg-gray-950 text-white w-full py-5 rounded-[2rem] font-black shadow-2xl hover:bg-black transition-colors" do %>
        📊 <span class="text-sm uppercase tracking-widest">全売上レポートを表示</span>
      <% end %>
    </div>
  </div>
</div>
<div class="max-w-md mx-auto p-4">
  <h1 class="text-2xl font-bold text-center mb-6">五月祭レジ記録</h1>

  <% if notice %>
    <div class="mb-4 p-2 bg-green-100 text-green-700 text-center rounded"><%= notice %></div>
  <% end %>

  <div class="mb-6 p-2 bg-gray-100 rounded">
    <p class="text-sm text-gray-600">直近の記録: 
      <% @sales.each do |s| %>
        <span class="inline-block bg-white px-2 py-1 rounded mr-1 shadow-sm text-xs">
          <%= s.item_type_jp %> | <%= s.gender_jp %>
        </span>
      <% end %>
    </p>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <% [
      { name: '商品A', type: 'item_a', price: 500, color: 'bg-blue-500' },
      { name: '商品B', type: 'item_b', price: 700, color: 'bg-red-500' }
    ].each do |item| %>
      
      <% ['male', 'female'].each do |gender| %>
        <% ['young', 'adult'].each do |age| %>
          <%= button_to sales_path(sale: { item_type: item[:type], gender: gender, age_group: age, price: item[:price] }), 
              class: "#{item[:color]} text-white h-24 rounded-xl shadow-lg active:scale-95 transition-transform text-sm font-bold flex flex-col justify-center items-center w-full" do %>
            <div class="text-lg"><%= item[:name] %></div>
            <div><%= gender == 'male' ? '♂ 男' : '♀ 女' %> / <%= age == 'young' ? '10-20' : '30+' %></div>
            <div class="opacity-80"><%= item[:price] %>円</div>
          <% end %>
        <% end %>
      <% end %>

    <% end %>
  </div>

  <div class="mt-10 text-center">
    <%= link_to '売上履歴・集計を確認する', manage_sales_path, class: "text-blue-600 underline" %>
  </div>
</div>
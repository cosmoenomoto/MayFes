<div class="max-w-md mx-auto p-6 bg-gray-50 min-h-screen">
  <div class="flex items-center gap-4 mb-8">
    <%= link_to root_path, class: "bg-white p-3 rounded-2xl shadow-sm" do %> ⬅️ <% end %>
    <h1 class="text-xl font-black text-gray-800">Analytics</h1>
  </div>
  
  <div class="bg-white p-8 rounded-[2rem] shadow-xl shadow-blue-100 border border-blue-50 mb-10 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50 rounded-full -mr-16 -mt-16 z-0"></div>
    <div class="relative z-10 text-center">
      <p class="text-xs font-bold text-blue-400 uppercase tracking-widest mb-1">Total Revenue</p>
      <p class="text-5xl font-black text-blue-600 tracking-tighter">
        <%= number_to_currency(@total_amount, unit: "¥", precision: 0) %>
      </p>
    </div>
  </div>

  <div class="space-y-4">
    <div class="flex justify-between items-end mb-4">
      <h2 class="font-black text-gray-800 text-lg italic">Timeline</h2>
      <span class="text-xs font-bold text-gray-400"><%= @sales.count %> Transactions</span>
    </div>

    <% @sales.each do |sale| %>
      <div class="group flex justify-between items-center bg-white p-5 rounded-3xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-2xl bg-gray-50 flex items-center justify-center text-xl">
            <%= sale.item_type == 'item_a' ? '🍕' : '🥤' %>
          </div>
          <div>
            <div class="font-black text-gray-800"><%= sale.item_type_jp %></div>
            <div class="text-[10px] font-bold text-gray-400 flex gap-2">
              <span class="text-blue-500 uppercase"><%= sale.gender_jp %></span>
              <span>•</span>
              <span><%= sale.created_at.strftime("%H:%M") %></span>
            </div>
          </div>
        </div>
        <div class="flex flex-col items-end gap-2">
          <div class="font-black text-gray-800">¥<%= sale.price %></div>
          <%= button_to sale_path(sale), method: :delete, data: { confirm: "削除しますか？" }, class: "opacity-0 group-hover:opacity-100 transition-opacity text-[10px] font-bold bg-rose-50 text-rose-500 px-3 py-1 rounded-full" do %>
            DELETE
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>